rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (get, update, delete) if the user is the owner of the profile.
     * @allow (create) if the user ID in the path matches the authenticated user's ID.
     * @deny Any other user attempting to read or write the profile.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource.data != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to game documents. Games are publicly readable, but create/update/delete require authentication.
     * @path /games/{gameId}
     * @allow (get, list) to everyone.
     * @allow (create) to authenticated users only
     * @deny (update, delete) always.
     * @principle Allows public read access to game data, but restricts write access to authenticated users.
     */
    match /games/{gameId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Controls access to team performance data within a game. Publicly readable, requires authentication to write.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (get, list) to everyone.
     * @allow (create) to authenticated users only.
     * @deny (update, delete) always.
     * @principle Allows public read access to performance data but restricts write access.
     */
    match /games/{gameId}/performance/{roundId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Controls access to student game state documents.
     * @path /studentGames/{userId}
     * @allow (get, update, delete) if the user is the owner of the document.
     * @allow (create) if the user ID in the path matches the authenticated user's ID.
     * @deny Any other user attempting to read or write the document.
     * @principle Enforces document ownership for student game states.
     */
    match /studentGames/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource.data != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }
  }
}