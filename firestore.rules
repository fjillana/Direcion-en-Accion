/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user profiles and student game states.
 * Games are publicly readable, but only owners can modify them.  Team performance data is secured under the game to which it belongs.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, accessible only by the user.
 * - /games/{gameId}: Stores game information, publicly readable but only modifiable by the owner.
 * - /games/{gameId}/performance/{roundId}: Stores team performance data for each round within a game, secured under the game.
 * - /studentGames/{userId}: Stores student game state, accessible only by the student.
 *
 * Key Security Decisions:
 * - User profiles and student game states are strictly private and accessible only to the respective user.
 * - Game data is publicly readable to allow discovery, but modifications are restricted to the owner.
 * - Listing of user documents is disallowed for privacy.
 *
 * Denormalization for Authorization:
 * - The data model includes owner information in the root documents to make security rules more efficient and secure.
 *
 * Structural Segregation:
 * - There are no mixed public/private collections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages user profile information.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' creates their own profile.
     *   - request.auth.uid: 'user123'
     *   - request.resource.data.id: 'user123'
     * @allow (get) User with ID 'user123' reads their own profile.
     *   - request.auth.uid: 'user123'
     * @allow (update) User with ID 'user123' updates their own profile.
     *   - request.auth.uid: 'user123'
     * @allow (delete) User with ID 'user123' deletes their own profile.
     *   - request.auth.uid: 'user123'
     * @deny (create) User with ID 'user123' attempts to create a profile for 'otherUser'.
     *   - request.auth.uid: 'user123'
     *   - request.resource.data.id: 'otherUser'
     * @deny (get) User with ID 'otherUser' attempts to read the profile of 'user123'.
     *   - request.auth.uid: 'otherUser'
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.auth.uid == userId;
      allow update: if isExistingOwner(userId) && request.auth.uid == userId;
      allow delete: if isExistingOwner(userId) && request.auth.uid == userId;
    }

    /**
     * @description Manages game information.
     * @path /games/{gameId}
     * @allow (get) Any user can read game information.
     *   - request.auth: null (or any user)
     * @allow (list) Any user can list games.
     *   - request.auth: null (or any user)
     * @allow (create) User with ID 'user123' creates a new game.
     *   - request.auth.uid: 'user123'
     * @allow (update) User with ID 'user123' updates a game they own.
     *   - request.auth.uid: 'user123'
     * @allow (delete) User with ID 'user123' deletes a game they own.
     *   - request.auth.uid: 'user123'
     * @deny (create) User with ID 'user123' attempts to create a game for 'otherUser'.
     *   - request.auth.uid: 'user123'
     * @deny (update) User with ID 'otherUser' attempts to update a game owned by 'user123'.
     *   - request.auth.uid: 'otherUser'
     * @principle Allows public read access with owner-only writes.
     */
    match /games/{gameId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages team performance data for each round within a game.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (get) Any user can read team performance data if they can read game.
     *   - request.auth: null (or any user)
     * @allow (list) Any user can list team performance data if they can read game.
     *   - request.auth: null (or any user)
     * @allow (create) User with ID 'user123' creates team performance data in a game they own.
     *   - request.auth.uid: 'user123'
     * @allow (update) User with ID 'user123' updates team performance data in a game they own.
     *   - request.auth.uid: 'user123'
     * @allow (delete) User with ID 'user123' deletes team performance data in a game they own.
     *   - request.auth.uid: 'user123'
     * @deny (create) User with ID 'user123' attempts to create performance data in a game owned by 'otherUser'.
     *   - request.auth.uid: 'user123'
     * @deny (update) User with ID 'otherUser' attempts to update performance data in a game owned by 'user123'.
     *   - request.auth.uid: 'otherUser'
     * @principle Enforces document ownership for writes, inherits read permissions from parent game.
     */
    match /games/{gameId}/performance/{roundId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages student game state information.
     * @path /studentGames/{userId}
     * @allow (create) User with ID 'user123' creates their own game state.
     *   - request.auth.uid: 'user123'
     * @allow (get) User with ID 'user123' reads their own game state.
     *   - request.auth.uid: 'user123'
     * @allow (update) User with ID 'user123' updates their own game state.
     *   - request.auth.uid: 'user123'
     * @allow (delete) User with ID 'user123' deletes their own game state.
     *   - request.auth.uid: 'user123'
     * @deny (create) User with ID 'user123' attempts to create a game state for 'otherUser'.
     *   - request.auth.uid: 'user123'
     * @deny (get) User with ID 'otherUser' attempts to read the game state of 'user123'.
     *   - request.auth.uid: 'otherUser'
     * @principle Enforces document ownership for all operations.
     */
    match /studentGames/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.auth.uid == userId;
      allow update: if isExistingOwner(userId) && request.auth.uid == userId;
      allow delete: if isExistingOwner(userId) && request.auth.uid == userId;
    }
  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}