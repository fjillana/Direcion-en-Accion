rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (get, update, delete) User with matching {userId}.
     * @allow (create) User creating their own profile.
     * @deny (get, update, delete) Any other user.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to game documents.
     * @path /games/{gameId}
     * @allow (create) Teacher creating a game.
     * @allow (get) Any user if their studentGame doc contains the gameId
     * @allow (update, delete) Teacher updating/deleting a game.
     * @deny (create, update, delete) Any other user.
     * @principle Enforces teacher-only management of games, student read based on the studentGames collection.
     */
    match /games/{gameId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isTeacher() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
      }

      function isStudentInGame(gameId) {
        return exists(/databases/$(database)/documents/studentGames/$(request.auth.uid))
            && get(/databases/$(database)/documents/studentGames/$(request.auth.uid)).data.gameId == gameId;
      }

      function isExistingTeacher() {
          return isTeacher() && resource != null;
      }
        
      allow get: if isSignedIn() && (isStudentInGame(gameId) || isTeacher()); // Students read if in game. Teachers should also be able to read
      allow list: if false;
      allow create: if isSignedIn() && isTeacher();
      allow update: if isSignedIn() && isExistingTeacher();
      allow delete: if isSignedIn() && isExistingTeacher();
    }

    /**
     * @description Controls access to team performance data within a game.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (create, update, delete) Teacher managing performance data.
     * @deny (get, list, create, update, delete) Any other user.
     * @principle Restricts performance data management to teachers.
     */
    match /games/{gameId}/performance/{roundId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isTeacher() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
      }

      function isExistingTeacher() {
          return isTeacher() && resource != null;
      }

      allow get: if isSignedIn() && isTeacher();
      allow list: if false;
      allow create: if isSignedIn() && isTeacher();
      allow update: if isSignedIn() && isExistingTeacher();
      allow delete: if isSignedIn() && isExistingTeacher();
    }

    /**
     * @description Controls access to student game state documents.
     * @path /studentGames/{userId}
     * @allow (get, update, delete) User with matching {userId}.
     * @allow (create) User creating their own game state.
     * @deny (get, update, delete) Any other user.
     *  @principle Enforces document ownership for student game states.
     */
    match /studentGames/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }
  }
}