rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their own profile.
     * @allow (get) User with ID 'user123' can read their own profile.
     * @allow (update) User with ID 'user123' can update their own profile.
     * @allow (delete) User with ID 'user123' can delete their own profile.
     * @deny (create) User with ID 'user456' cannot create a profile for 'user123'.
     * @deny (get) User with ID 'user456' cannot read the profile of 'user123'.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /users/{userId} {
      // Verify the identity of the user.
      function isSignedIn() {
        return request.auth != null;
      }

      // Check if the requested user id matches the authenticated user id.
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      // Check if the user is an existing owner of the document.
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      // Allow the user to read their own profile.
      allow get: if isSignedIn() && isOwner(userId);

      // Prevent listing of all users.
      allow list: if false;

      // Allow a user to create their own profile, enforcing that the userId in the path matches the authenticated user's ID.
      allow create: if isSignedIn() && isOwner(userId);

      // Allow a user to update their own profile, enforcing ownership and document existence.
      allow update: if isSignedIn() && isExistingOwner(userId);

      // Allow a user to delete their own profile, enforcing ownership and document existence.
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to game documents.  Games are publicly readable, but not writable.
     * @path /games/{gameId}
     * @allow (get) Any user can read game data.
     * @allow (list) Any user can list game data.
     * @deny (create) No one can create game documents through the client.
     * @deny (update) No one can update game documents through the client.
     * @deny (delete) No one can delete game documents through the client.
     * @principle Public read, owner-only writes (currently, no owner, so writes are always denied).
     */
    match /games/{gameId} {
      // Allow anyone to read game data.
      allow get, list: if true;

      // Nobody can create, update, or delete games.
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to team performance documents within a game. Performance data is publicly readable, but not writable.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (get) Any user can read team performance data.
     * @allow (list) Any user can list team performance data.
     * @deny (create) No one can create team performance documents through the client.
     * @deny (update) No one can update game documents through the client.
     * @deny (delete) No one can delete game documents through the client.
     * @principle Public read, owner-only writes (currently, no owner, so writes are always denied).
     */
    match /games/{gameId}/performance/{roundId} {
      // Allow anyone to read team performance data.
      allow get, list: if true;

      // Nobody can create, update, or delete performance data.
      allow create, update, delete: if false;
    }

     /**
     * @description Controls access to student game state documents.
     * @path /studentGames/{userId}
     * @allow (create) User with ID 'user123' can create their own game state.
     * @allow (get) User with ID 'user123' can read their own game state.
     * @allow (update) User with ID 'user123' can update their own game state.
     * @allow (delete) User with ID 'user123' can delete their own game state.
     * @deny (create) User with ID 'user456' cannot create a game state for 'user123'.
     * @deny (get) User with ID 'user456' cannot read the game state of 'user123'.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /studentGames/{userId} {
      // Verify the identity of the user.
      function isSignedIn() {
        return request.auth != null;
      }

      // Check if the requested user id matches the authenticated user id.
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      // Check if the user is an existing owner of the document.
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      // Allow the user to read their own game state.
      allow get: if isSignedIn() && isOwner(userId);

      // Prevent listing of all users.
      allow list: if false;

      // Allow a user to create their own game state, enforcing that the userId in the path matches the authenticated user's ID.
      allow create: if isSignedIn() && isOwner(userId);

      // Allow a user to update their own game state, enforcing ownership and document existence.
      allow update: if isSignedIn() && isExistingOwner(userId);

      // Allow a user to delete their own game state, enforcing ownership and document existence.
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }
  }
}