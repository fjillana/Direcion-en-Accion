/**
 * @fileOverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for user profiles and student game states,
 * while games and their performance data are accessible to all users.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, accessible only to the user themselves.
 * - /games/{gameId}: Stores game information, publicly readable but writable by no one.
 * - /games/{gameId}/performance/{roundId}: Stores team performance data for each round, publicly readable but writable by no one.
 * - /studentGames/{userId}: Stores the game state for each student, accessible only to the student themselves.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Games and TeamPerformance are read only
 * - Strict ownership is enforced for user profiles and student game states.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows a user to read and write their own profile data.
     * @path /users/{userId}
     * @allow (get, list, create, update, delete) User with matching {userId} can access their own profile.
     * @deny (get, list, create, update, delete) User tries to access a different user's profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Allows anyone to read Games. No writes allowed for anyone.
     * @path /games/{gameId}
     * @allow (get, list) Any signed in user can read games.
     * @deny (create, update, delete) No one can create, update, or delete games.
     * @principle Games are publicly readable but not writable.
     */
    match /games/{gameId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read team performance data. No writes allowed for anyone.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (get, list) Any signed in user can read team performance data.
     * @deny (create, update, delete) No one can create, update, or delete team performance data.
     * @principle Team performance data is publicly readable but not writable.
     */
    match /games/{gameId}/performance/{roundId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows a user to read and write their own game state.
     * @path /studentGames/{userId}
     * @allow (get, list, create, update, delete) User with matching {userId} can access their own game state.
     * @deny (get, list, create, update, delete) User tries to access a different user's game state.
     * @principle Enforces document ownership for all operations.
     */
    match /studentGames/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }
  }
}