/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a user-ownership model for user profiles and student game states,
 * and allows public read access to game information with owner-only write access.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, only accessible by the user themselves.
 * - /games/{gameId}: Stores game information, publicly readable, but only modifiable by the game's creator.
 * - /games/{gameId}/performance/{roundId}: Stores team performance data for each round of a game, only accessible by the game creator.
 * - /studentGames/{userId}: Stores the game state for each student, only accessible by the student themselves.
 *
 * Key Security Decisions:
 * - Users can only read and write their own profile data and student game state.
 * - Games are publicly readable but only the creator can modify them.
 * - Listing of users is disallowed for privacy.
 *
 * Denormalization for Authorization:
 * - The 'Game' entity should contain an 'ownerId' or 'creatorId' field to identify the user who created the game. This is essential for controlling write access.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (create) User 'user_abc' can create their profile if request.auth.uid == userId.
     * @allow (get, update, delete) User 'user_abc' can get, update, or delete their profile if request.auth.uid == userId.
     * @deny (create, get, update, delete) User 'user_xyz' cannot access 'user_abc' profile.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      // Make sure the uid of the requesting user matches the user id of the document.
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow get, update, delete: if isSignedIn() && isExistingOwner(userId) && resource.data.id == userId;
      allow list: if false;
    }

    /**
     * @description Controls access to game information.
     * @path /games/{gameId}
     * @allow (get, list) Anyone can read game information.
     * @allow (create) User 'user_abc' can create a game if request.auth.uid == request.resource.data.ownerId.
     * @allow (update, delete) User 'user_abc' can update or delete the game if they are the owner (resource.data.ownerId == request.auth.uid).
     * @deny (create, update, delete) User 'user_xyz' cannot modify a game they don't own.
     * @principle Allows public read access with owner-only writes for games.
     */
    match /games/{gameId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && isExistingOwner(resource.data.ownerId);
    }

    /**
     * @description Controls access to team performance data for a specific game and round.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (create) User 'user_abc' can create team performance data if they own the game (get(/databases/$(database)/documents/games/$(gameId)).data.ownerId == request.auth.uid).
     * @allow (get, list, update, delete) User 'user_abc' can get, list, update, or delete team performance data if they own the game (get(/databases/$(database)/documents/games/$(gameId)).data.ownerId == request.auth.uid).
     * @deny (create, get, list, update, delete) User 'user_xyz' cannot access team performance data for a game they don't own.
     */
    match /games/{gameId}/performance/{roundId} {
       allow create: if isSignedIn() && get(/databases/$(database)/documents/games/$(gameId)).data.ownerId == request.auth.uid;
       allow get, list, update, delete: if isSignedIn() && get(/databases/$(database)/documents/games/$(gameId)).data.ownerId == request.auth.uid;
    }

    /**
     * @description Controls access to student game state.
     * @path /studentGames/{userId}
     * @allow (create) User 'user_abc' can create their student game state if request.auth.uid == userId && request.resource.data.userId == userId.
     * @allow (get, update, delete) User 'user_abc' can get, update, or delete their student game state if request.auth.uid == userId.
     * @deny (create, get, update, delete) User 'user_xyz' cannot access 'user_abc' student game state.
     * @principle Enforces document ownership for student game state.
     */
    match /studentGames/{userId} {
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow get, update, delete: if isSignedIn() && isExistingOwner(userId) && resource.data.userId == userId;
      allow list: if isOwner(userId);
    }

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(ownerId) {
        return isSignedIn() && request.auth.uid == ownerId && resource != null;
    }
  }
}