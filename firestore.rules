/**
 * @file Firestore Security Rules
 * @core_philosophy This ruleset enforces a user-ownership model for user profiles and student game states. Games are publicly readable, but only authorized users can modify them. Team performance data is restricted to game administrators.
 * @data_structure
 *   - /users/{userId}: Stores user profile information.
 *   - /games/{gameId}: Stores game information.
 *   - /games/{gameId}/performance/{roundId}: Stores team performance data for each round of a game.
 *   - /studentGames/{userId}: Stores the game state for each student.
 * @key_security_decisions
 *   - User listing is disallowed to protect privacy.
 *   - Games are publicly readable to facilitate discovery.
 *   - Only the owner can modify their user profile and student game state.
 *   - Game updates are not owner-only restricted during prototyping to allow for ease of development, but this MUST be secured in production.
 * @denormalization_for_authorization
 *   - No denormalization is explicitly used in this version, but it is recommended to add an owner field to the Game entity in the future to restrict write access to the game creator/admin.
 * @structural_segregation Public data is stored in top-level collections (e.g., /games), while private data is stored under the /users collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (create) - If the authenticated user's ID matches the userId.
     * @allow (get, list, update, delete) - If the authenticated user's ID matches the userId.
     * @deny (create) - If the authenticated user's ID does not match the userId.
     * @deny (get, list, update, delete) - If the authenticated user's ID does not match the userId.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      // Verifies that the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Verifies that the userId matches the authenticated user's ID.
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Controls access to game documents.
     * @path /games/{gameId}
     * @allow (get, list) - Any user can read game information.
     * @allow (create, update, delete) - Unrestricted writes during prototyping. MUST be secured in production.
     * @deny (none) - No requests are explicitly denied during prototyping.
     * @principle Allows public read access with unrestricted writes for prototyping.
     */
    match /games/{gameId} {
      allow get, list: if true;
      allow create, update, delete: if true; // TODO: Secure this in production.
    }

    /**
     * @description Controls access to team performance documents.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (none) - No read or write access is granted in this initial ruleset.
     * @deny (get, list, create, update, delete) - All requests are denied.
     * @principle Restricts all access to team performance data.
     */
    match /games/{gameId}/performance/{roundId} {
      allow get, list, create, update, delete: if false;
    }

    /**
     * @description Controls access to student game state documents.
     * @path /studentGames/{userId}
     * @allow (create) - If the authenticated user's ID matches the userId.
     * @allow (get, list, update, delete) - If the authenticated user's ID matches the userId.
     * @deny (create) - If the authenticated user's ID does not match the userId.
     * @deny (get, list, update, delete) - If the authenticated user's ID does not match the userId.
     * @principle Enforces document ownership for all operations.
     */
    match /studentGames/{userId} {
      // Verifies that the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Verifies that the userId matches the authenticated user's ID.
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }
  }
}