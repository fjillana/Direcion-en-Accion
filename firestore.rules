/**
 * @file Firestore Security Rules
 * @description This ruleset allows all authenticated users to read and write any data in the Firestore database.
 *
 * Core Philosophy: All authenticated users can perform any operation. There are no restrictions based on user roles or data ownership.
 * Data Structure:
 * - /users/{userId}: Stores user profile information.
 * - /games/{gameId}: Stores game session data.
 * - /games/{gameId}/performance/{roundId}: Stores team performance data for each round of a game.
 * - /studentGames/{userId}: Stores the game state for each student user.
 * Key Security Decisions:
 * - No user-specific or role-based access control is enforced.
 * - All authenticated users are treated as equals with full read/write access.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows any authenticated user to read and write user profile information.
     * @path /users/{userId}
     * @allow (get, list, create, update, delete) - Any authenticated user can perform any operation.
     * @deny None
     * @principle No access control. All authenticated users have full access.
     */
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read and write game session data.
     * @path /games/{gameId}
     * @allow (get, list, create, update, delete) - Any authenticated user can perform any operation.
     * @deny None
     * @principle No access control. All authenticated users have full access.
     */
    match /games/{gameId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();

      /**
       * @description Allows any authenticated user to read and write team performance data for each round of a game.
       * @path /games/{gameId}/performance/{roundId}
       * @allow (get, list, create, update, delete) - Any authenticated user can perform any operation.
       * @deny None
       * @principle No access control. All authenticated users have full access.
       */
      match /performance/{roundId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }
    }

    /**
     * @description Allows any authenticated user to read and write student game state data.
     * @path /studentGames/{userId}
     * @allow (get, list, create, update, delete) - Any authenticated user can perform any operation.
     * @deny None
     * @principle No access control. All authenticated users have full access.
     */
    match /studentGames/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }

  // Helper function to check if the user is signed in.
  function isSignedIn() {
    return request.auth != null;
  }
}