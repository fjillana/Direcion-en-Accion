/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user profiles and student game states. Games are publicly readable, but only authenticated users can create, update, or delete them. Team performance data is accessible to authenticated users only.
 * @dataStructure
 *   - /users/{userId}: Stores user profile information.
 *   - /games/{gameId}: Stores game information.
 *   - /games/{gameId}/performance/{roundId}: Stores team performance data for each round in a game.
 *   - /studentGames/{userId}: Stores the game state for each student.
 * @keySecurityDecisions
 *   - Users can only read/write their own profile data.
 *   - Games are publicly readable but creation, modification, and deletion are restricted to authenticated users.
 *   - Listing of users is disallowed for privacy.
 *   - Users can only read/write their own student game state.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (create) - User with UID 'user123' can create their profile if request.auth.uid == 'user123'.
     * @allow (get, update, delete) - User with UID 'user123' can get, update, or delete their profile.
     * @deny (create) - User with UID 'user456' cannot create a profile for 'user123'.
     * @deny (get, update, delete) - User with UID 'user456' cannot get, update, or delete the profile for 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Listing users is not permitted.
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Controls access to game information.
     * @path /games/{gameId}
     * @allow (get, list) - Any user can read game information.
     * @allow (create) - Any authenticated user can create a game.
     * @allow (update, delete) - Only authenticated users can update or delete a game.
     * @deny (create) - Unauthenticated user cannot create a game.
     * @deny (update, delete) - Unauthenticated user cannot update or delete a game.
     * @principle Allows public read access but restricts write access to authenticated users.
     */
    match /games/{gameId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Controls access to team performance data for each round in a game.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (get, list, create, update, delete) - Any authenticated user can access team performance data.
     * @deny (get, list, create, update, delete) - Unauthenticated users cannot access team performance data.
     * @principle Restricts access to team performance data to authenticated users.
     */
    match /games/{gameId}/performance/{roundId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    /**
     * @description Controls access to student game state information.
     * @path /studentGames/{userId}
     * @allow (create) - User with UID 'user123' can create their student game state if request.auth.uid == 'user123'.
     * @allow (get, update, delete) - User with UID 'user123' can get, update, or delete their student game state.
     * @deny (create) - User with UID 'user456' cannot create a student game state for 'user123'.
     * @deny (get, update, delete) - User with UID 'user456' cannot get, update, or delete the student game state for 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /studentGames/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
    }

    // --- Helper functions ---

    /**
     * @description Checks if the request is made by the owner of the resource.
     * @param {string} userId The user ID to compare against the request's authentication UID.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }
  }
}