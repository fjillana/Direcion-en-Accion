rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows only the authenticated user to read and write their own profile.
     * @path /users/{userId}
     * @allow (get, create, update, delete) - User 'alice' (auth.uid: 'alice_uid') can read/write her profile at /users/alice_uid.
     * @deny (get, create, update, delete) - User 'bob' (auth.uid: 'bob_uid') cannot read/write Alice's profile at /users/alice_uid.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Allows teachers to create, update, and delete games they own. Allows anyone to read the game.
     * @path /games/{gameId}
     * @allow (get, list) - Any user can read game data.
     * @allow (create) - Teacher 'teacher_uid' can create a game at /games/game1 if request.resource.data.createdBy == 'teacher_uid'.
     * @allow (update, delete) - Teacher 'teacher_uid' can update/delete a game at /games/game1 only if they created it (createdBy == 'teacher_uid').
     * @deny (create) - User 'student_uid' cannot create a game at /games/game1 with request.resource.data.createdBy == 'teacher_uid'.
     * @deny (update, delete) - User 'student_uid' cannot update/delete a game at /games/game1 even if they know the game ID.
     * @principle Enforces document ownership for writes; allows public reads.
     */
    match /games/{gameId} {
      function isTeacher() {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
      }
      function isGameOwner(gameId) {
        return get(/databases/$(database)/documents/games/$(gameId)).data.createdBy == request.auth.uid;
      }
      function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if true;
      allow create: if isSignedIn() && isTeacher() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn() && isTeacher() && isGameOwner(gameId);
      allow delete: if isSignedIn() && isTeacher() && isGameOwner(gameId);
    }

    /**
     * @description Allows teachers who own the game to read and write performance data.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (get, list, create, update, delete) - Teacher 'teacher_uid' can read/write performance data for game 'game1' if they created the game.
     * @deny (get, list, create, update, delete) - User 'student_uid' cannot read/write performance data for any game.
     * @principle Enforces document ownership for writes on a subcollection.
     */
    match /games/{gameId}/performance/{roundId} {
       function isTeacher() {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
      }
      function isGameOwner(gameId) {
        return get(/databases/$(database)/documents/games/$(gameId)).data.createdBy == request.auth.uid;
      }
        function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if isSignedIn() && isTeacher() && isGameOwner(gameId);
      allow create: if isSignedIn() && isTeacher() && isGameOwner(gameId);
      allow update: if isSignedIn() && isTeacher() && isGameOwner(gameId);
      allow delete: if isSignedIn() && isTeacher() && isGameOwner(gameId);
    }

    /**
     * @description Allows a student to manage their own game state.
     * @path /studentGames/{userId}
     * @allow (get, create, update, delete) - Student 'student_uid' can read/write their game state at /studentGames/student_uid.
     * @deny (get, create, update, delete) - User 'teacher_uid' cannot read/write student Alice's game state at /studentGames/alice_uid.
     * @principle Enforces document ownership for writes.
     */
    match /studentGames/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
       function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }
  }
}