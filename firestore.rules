/**
 * @fileoverview Firestore Security Rules for the "Ciman" application.
 *
 * Core Philosophy:
 * This ruleset employs a strict user-ownership model for user profiles and student game states.
 * Games and their performance data are publicly readable but only modifiable by authenticated users.
 *
 * Data Structure:
 * - /users/{userId}: Stores individual user profiles, accessible only to the owning user.
 * - /games/{gameId}: Stores game information, publicly readable.
 * - /games/{gameId}/performance/{roundId}: Stores performance data for each round of a game, publicly readable.
 * - /studentGames/{userId}: Stores the game state for each student, accessible only to the student.
 *
 * Key Security Decisions:
 * - User listing is disallowed to protect privacy.
 * - Public read access is granted to game and performance data to facilitate open participation and analysis.
 * - All write operations are protected by authorization checks to prevent unauthorized data modification.
 *
 * Denormalization for Authorization:
 * - The `studentGames` documents are named with the `userId` to allow ownership checks without additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to user profile information.
     * @path /users/{userId}
     * @allow (create) - Authenticated user with matching userId can create their own profile.
     * @allow (get, update, delete) - Authenticated user with matching userId can get, update, and delete their own profile.
     * @deny (create, get, update, delete) - Any other user attempting to access another user's profile.
     * @deny (list) - Listing users is not allowed.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      //  Helper function to determine if the user is signed in and is the owner
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      // Helper function to determine if the user is signed in and is the existing owner of the data
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages access to game information.
     * @path /games/{gameId}
     * @allow (get, list) - Any user can read game information.
     * @allow (create, update, delete) - Only authenticated users can create, update or delete game information.
     * @principle Allows public read access with authenticated-user-only writes.
     */
    match /games/{gameId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to team performance data for each round of a game.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (get, list) - Any user can read team performance data.
     * @allow (create, update, delete) - Only authenticated users can create, update or delete team performance data.
     * @principle Allows public read access with authenticated-user-only writes.
     */
    match /games/{gameId}/performance/{roundId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to student game state information.
     * @path /studentGames/{userId}
     * @allow (create) - Authenticated user with matching userId can create their own game state.
     * @allow (get, update, delete) - Authenticated user with matching userId can get, update, and delete their own game state.
     * @deny (create, get, update, delete) - Any other user attempting to access another user's game state.
     * @deny (list) - Listing student game states is not allowed.
     * @principle Enforces document ownership for all operations.
     */
    match /studentGames/{userId} {
       //  Helper function to determine if the user is signed in and is the owner
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      // Helper function to determine if the user is signed in and is the existing owner of the data
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }
  }
}