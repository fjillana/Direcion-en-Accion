
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // WARNING: This is an insecure rule. 
    // It allows anyone to read and write to any part of your database.
    // This should only be used for initial development and MUST be secured
    // before any real users access the application.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
