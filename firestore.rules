/**
 * @file Firestore Security Rules
 * @version 2
 *
 * @Core Philosophy
 * This ruleset enforces a user-ownership model for user profiles and student game states,
 * and open read access with owner-only writes for games and team performance data.
 *
 * @Data Structure
 * - /users/{userId}: Stores user profile information, accessible only by the user.
 * - /games/{gameId}: Stores game data, publicly readable but writable only by the game's creator (not yet implemented).
 * - /games/{gameId}/performance/{roundId}: Stores team performance data for each round, publicly readable but writable only by the game's creator (not yet implemented).
 * - /studentGames/{userId}: Stores the game state for each student, accessible only by the student.
 *
 * @Key Security Decisions
 * - User listing is disallowed to protect user privacy.
 * - Public read access is granted to the /games and /games/{gameId}/performance collections to allow open data consumption.
 * - Strict ownership is enforced for user profiles and student game states.
 *
 * @Denormalization for Authorization
 *  Not applicable in the current schema.  Future iterations could include denormalizing an "ownerId" field onto the /games collection.
 *
 * @Structural Segregation
 *  Not applicable in the current schema.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages user profile data, restricting access to the owning user.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their profile with matching ID.
     * @allow (get) User with ID 'user123' can read their own profile.
     * @deny (get) User with ID 'user456' cannot read the profile of user 'user123'.
     * @deny (update) User with ID 'user456' cannot update the profile of user 'user123'.
     * @deny (delete) User with ID 'user456' cannot delete the profile of user 'user123'.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Manages game data, allowing public read access but restricting writes to the game creator.
     * @path /games/{gameId}
     * @allow (get) Any user can read a game's data.
     * @allow (list) Any user can list games.
     * @deny (create) Any user cannot create a game (missing ownership field validation).
     * @deny (update) Any user cannot update a game (missing ownership field validation).
     * @deny (delete) Any user cannot delete a game (missing ownership field validation).
     * @principle Allows public read access with owner-only writes.
     */
    match /games/{gameId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.auth != null; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Manages team performance data, allowing public read access but restricting writes to the game creator.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (get) Any user can read team performance data.
     * @allow (list) Any user can list team performance data.
     * @deny (create) Any user cannot create team performance data (missing ownership field validation).
     * @deny (update) Any user cannot update team performance data (missing ownership field validation).
     * @deny (delete) Any user cannot delete team performance data (missing ownership field validation).
     * @principle Allows public read access with owner-only writes.
     */
    match /games/{gameId}/performance/{roundId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.auth != null; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Manages student game state, restricting access to the owning student.
     * @path /studentGames/{userId}
     * @allow (create) User with ID 'user123' can create their game state with matching ID.
     * @allow (get) User with ID 'user123' can read their own game state.
     * @deny (get) User with ID 'user456' cannot read the game state of user 'user123'.
     * @deny (update) User with ID 'user456' cannot update the game state of user 'user123'.
     * @deny (delete) User with ID 'user456' cannot delete the game state of user 'user123'.
     * @principle Enforces document ownership for writes.
     */
    match /studentGames/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
  }
}