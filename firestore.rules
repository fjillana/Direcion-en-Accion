/**
 * @file Firebase Security Rules for the application.
 *
 * @corePhilosophy This ruleset enforces a user-ownership model for user profiles and student game states. Games and their performance data are readable by everyone, but only authorized users can create, update, or delete them.
 * @dataStructure
 *   - /users/{userId}: Stores user profile information, accessible only to the user themselves.
 *   - /games/{gameId}: Stores game information, publicly readable but writable only by authenticated users.
 *   - /games/{gameId}/performance/{roundId}: Stores team performance data, publicly readable but writable only by authenticated users.
 *   - /studentGames/{userId}: Stores the game state for each student, accessible only to the student themselves.
 * @keySecurityDecisions
 *   - User listing is disallowed to prevent unauthorized access to user data.
 *   - Public read access is granted to games and their performance data for open data consumption.
 *   - Strict ownership is enforced for user profiles and student game states.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (read, write): Authenticated user with matching userId can read/write their own profile.
     * @deny (read, write): Authenticated user trying to access another user's profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false; // Disable user listing

      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.email == request.auth.token.email;
      allow update: if isSignedIn() && isOwner(userId) && request.resource.data.email == resource.data.email;
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Controls access to game documents.
     * @path /games/{gameId}
     * @allow (read): Any user can read game documents.
     * @allow (create, update, delete): Only authenticated users can create, update, or delete game documents.
     * @deny (create, update, delete): Unauthenticated users cannot create, update, or delete game documents.
     */
    match /games/{gameId} {
      function isSignedIn() {
        return request.auth != null;
      }
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Controls access to team performance documents within a game.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (read): Any user can read team performance documents.
     * @allow (create, update, delete): Only authenticated users can create, update, or delete team performance documents.
     * @deny (create, update, delete): Unauthenticated users cannot create, update, or delete team performance documents.
     */
    match /games/{gameId}/performance/{roundId} {
      function isSignedIn() {
        return request.auth != null;
      }
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Controls access to student game state documents.
     * @path /studentGames/{userId}
     * @allow (read, write): Authenticated user with matching userId can read/write their own game state.
     * @deny (read, write): Authenticated user trying to access another user's game state.
     * @principle Enforces document ownership for all operations.
     */
    match /studentGames/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false; // Disable user listing

      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && resource != null;
      allow delete: if isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}