/**
 * @file Firebase Security Rules for the application.
 *
 * @core_philosophy This ruleset enforces a user-ownership model for user profiles and student game states.
 * Games are publicly readable, but only authorized users can create, update, or delete them. Team performance data is restricted.
 *
 * @data_structure
 * - /users/{userId}: Stores user profile information, accessible only to the user themselves.
 * - /games/{gameId}: Stores game information, publicly readable, writable by authenticated users.
 * - /games/{gameId}/performance/{roundId}: Stores team performance data, only accessible to the game creator
 * - /studentGames/{userId}: Stores the game state for each student user, accessible only to the user themselves.
 *
 * @key_security_decisions
 * - User listing is disallowed for privacy.
 * - Public read access is granted to the /games collection to enable discovery and participation, but write permissions are restricted.
 * - The default security posture for ambiguous relationships is strict owner-only access.
 *
 * @denormalization_for_authorization
 *  N/A
 *
 * @structural_segregation
 *  N/A
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures user profile data, allowing only the owner to read and write.
     * @path /users/{userId}
     * @allow (get, update, delete) User with ID 'user123' can read, update, and delete their own profile.
     * @allow (create) User with ID 'user123' can create their profile if request.auth.uid == userId.
     * @deny (get, update, delete) User with ID 'user456' cannot access 'user123' profile.
     * @deny (create) User with ID 'user456' cannot create 'user123' profile.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isSignedIn() {
          return request.auth != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Secures the games collection, allowing public read access but restricting writes.
     * @path /games/{gameId}
     * @allow (get, list) Any user can read the game data.
     * @allow (create, update, delete) Authenticated users can modify games data.
     * @deny (create, update, delete) Unauthenticated users cannot modify game data.
     * @principle Allows public read access while enforcing authentication for write operations.
     */
    match /games/{gameId} {
      function isSignedIn() {
          return request.auth != null;
      }

      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Secures team performance data, restricting access to the game creator.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (get, list) Any user can read the performance data.
     * @deny (create, update, delete) No users can write performance data.
     * @principle  Restricts access to the team performance data.
     */
    match /games/{gameId}/performance/{roundId} {
          function isGameCreator(gameId) {
            return get(/databases/$(database)/documents/games/$(gameId)).data.creatorId == request.auth.uid;
          }

      allow get: if isGameCreator(gameId);
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Secures student game state data, allowing only the owner to read and write.
     * @path /studentGames/{userId}
     * @allow (get, update, delete) User with ID 'user123' can read, update, and delete their own game state.
     * @allow (create) User with ID 'user123' can create their game state if request.auth.uid == userId.
     * @deny (get, update, delete) User with ID 'user456' cannot access 'user123' game state.
     * @deny (create) User with ID 'user456' cannot create 'user123' game state.
     * @principle Enforces document ownership for writes and restricts access to a user's own data.
     */
    match /studentGames/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isSignedIn() {
          return request.auth != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }
  }
}