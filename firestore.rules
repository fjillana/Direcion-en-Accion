/**
 * @file Overview
 * This ruleset enforces a role-based access control model with teacher and student roles.
 * User profiles are stored under `/users/{userId}` and are only accessible by the user themselves.
 * Games are stored under `/games/{gameId}`. Only teachers can create, update or delete them.
 * Team performance data is stored under `/games/{gameId}/performance/{roundId}` and only teachers can access this.
 * Student game states are stored under `/studentGames/{userId}` and are accessible only by the student themselves and teachers.
 *
 * Data Structure:
 * - /users/{userId}: User profile information.
 * - /games/{gameId}: Game information.
 * - /games/{gameId}/performance/{roundId}: Performance data for each round of a game.
 * - /studentGames/{userId}: Game state for each student.
 *
 * Key Security Decisions:
 * - Only authenticated users can access the database.
 * - Users can only read and write their own profile data.
 * - Only teachers can create, update, and delete games and team performance data.
 * - Students can only access their own game state.
 *
 * Denormalization for Authorization:
 * - Teacher role is denormalized on the user profile to simplify game management rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own profile data.
     * @path /users/{userId}
     * @allow (get, update, delete) User with ID 'user123' can read/write their profile.
     * @allow (create) User with ID 'user123' can create their profile if request.auth.uid == 'user123'.
     * @deny (get, update, delete) User with ID 'user456' cannot read/write the profile of user with ID 'user123'.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows teachers to create, read, update, and delete games.
     * @path /games/{gameId}
     * @allow (create) Teacher can create a new game.
     * @allow (get, list) Anyone can read game information.
     * @allow (update, delete) Teacher can update or delete the game.
     * @deny (create, update, delete) Student cannot create, update, or delete games.
     * @principle Restricts game management to teachers.
     */
    match /games/{gameId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isTeacher() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
      }
        
      allow get, list: if true;
      allow create: if isSignedIn() && isTeacher();
      allow update: if isSignedIn() && isTeacher() && resource != null;
      allow delete: if isSignedIn() && isTeacher() && resource != null;
    }

    /**
     * @description Allows teachers to create, read, update, and delete team performance data for a specific game and round.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (create) Teacher can create team performance data for a specific game and round.
     * @allow (get, list) Teacher can read team performance data for a specific game and round.
     * @allow (update, delete) Teacher can update or delete team performance data for a specific game and round.
     * @deny (create, get, list, update, delete) Student cannot create, read, update, or delete team performance data.
     * @principle Restricts team performance data management to teachers.
     */
    match /games/{gameId}/performance/{roundId} {
        function isSignedIn() {
            return request.auth != null;
        }

        function isTeacher() {
            return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
        }

        allow get, list: if isSignedIn() && isTeacher();
        allow create: if isSignedIn() && isTeacher();
        allow update: if isSignedIn() && isTeacher() && resource != null;
        allow delete: if isSignedIn() && isTeacher() && resource != null;
    }

    /**
     * @description Allows users and teachers to read and write their own game state data.
     * @path /studentGames/{userId}
     * @allow (get, update, delete) User with ID 'user123' or a teacher can read/write the game state.
     * @allow (create) User with ID 'user123' can create their game state if request.auth.uid == 'user123'.
     * @deny (get, update, delete) User with ID 'user456' cannot read/write the game state of user with ID 'user123'.
     * @principle Enforces document ownership for student game states.
     */
    match /studentGames/{userId} {
        function isOwner(userId) {
            return request.auth != null && request.auth.uid == userId;
        }

        function isSignedIn() {
            return request.auth != null;
        }

        function isTeacher() {
            return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
        }

        allow get: if isOwner(userId) || (isSignedIn() && isTeacher());
        allow list: if isOwner(userId) || (isSignedIn() && isTeacher());
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || (isSignedIn() && isTeacher() && resource != null);
        allow delete: if isOwner(userId) || (isSignedIn() && isTeacher() && resource != null);
    }
  }
}