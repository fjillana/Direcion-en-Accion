rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (create, update, get, delete) User with ID 'user123' can create/update/get/delete their own profile.
     * @deny (create, update, get, delete) User with ID 'user456' cannot access profile data for 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      //Function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Function to check if the requested user id matches the authenticated user id
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Controls access to game data.
     * @path /games/{gameId}
     * @allow (get, list) Any user can read game data.
     * @allow (create) User 'user123' can create a game with ownerId set to 'user123'.
     * @allow (update, delete) User 'user123' can update/delete a game where resource.data.ownerId == 'user123'.
     * @deny (create) User 'user123' cannot create a game with ownerId set to 'user456'.
     * @deny (update, delete) User 'user456' cannot update/delete a game where resource.data.ownerId == 'user123'.
     * @principle Allows public read access but restricts write access to the owner.
     */
    match /games/{gameId} {
      //Function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Function to check if the user is the owner of the game
      function isOwner(ownerId) {
        return isSignedIn() && request.auth.uid == ownerId;
      }

       // Function to check if the user is the owner of the game being created
      function isCreatingOwner() {
        return isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      }

      // Function to check if the requested user id matches the authenticated user id and that the document exists
      function isExistingOwner() {
        return isSignedIn() && request.auth.uid == resource.data.ownerId;
      }

      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isCreatingOwner();
      allow update: if isSignedIn() && isExistingOwner();
      allow delete: if isSignedIn() && isExistingOwner();
    }

    /**
     * @description Controls access to team performance data within a game.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (get, list) Any user can read team performance data.
     * @allow (create) User 'user123' can create team performance data in game owned by 'user123'.
     * @allow (update, delete) User 'user123' can update/delete team performance data in game owned by 'user123'.
     * @deny (create) User 'user123' cannot create team performance data in game owned by 'user456'.
     * @deny (update, delete) User 'user456' cannot update/delete team performance data in game owned by 'user123'.
     * @principle Allows public read access but restricts write access to the game owner.
     */
    match /games/{gameId}/performance/{roundId} {
       //Function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Function to check if the user is the owner of the game
      function isGameOwner(gameId) {
        return isSignedIn() && get(/databases/$(database)/documents/games/$(gameId)).data.ownerId == request.auth.uid;
      }


      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isGameOwner(gameId);
      allow update: if isSignedIn() && isGameOwner(gameId);
      allow delete: if isSignedIn() && isGameOwner(gameId);
    }

    /**
     * @description Controls access to student game state data.
     * @path /studentGames/{userId}
     * @allow (create, update, get, delete) User with ID 'user123' can create/update/get/delete their own game state.
     * @deny (create, update, get, delete) User with ID 'user456' cannot access game state data for 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /studentGames/{userId} {
       //Function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Function to check if the requested user id matches the authenticated user id
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }
  }
}