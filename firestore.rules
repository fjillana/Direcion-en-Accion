/**
 * @file Firebase Security Rules for Firestore.
 *
 * @core_philosophy This ruleset enforces a strict user-ownership model for user profiles
 * and student game states. Games are publicly readable, but writes are not allowed.
 * Performance data is also publicly readable, but writes are disallowed.
 *
 * @data_structure
 * - /users/{userId}: Stores user profile information, accessible only by the user.
 * - /games/{gameId}: Stores game information, publicly readable.
 * - /games/{gameId}/performance/{roundId}: Stores team performance data, publicly readable.
 * - /studentGames/{userId}: Stores the game state for a student, accessible only by the student.
 *
 * @key_security_decisions
 * - User listing is disallowed to protect user privacy.
 * - Games and team performance data are publicly readable to allow open access to game results.
 * - Writes to games and team performance data are denied.
 * - Student game states are owned by the user.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (create) User 'test_user' with ID 'test_user' can create their profile.
     * @allow (get) User 'test_user' with ID 'test_user' can read their profile.
     * @allow (update) User 'test_user' with ID 'test_user' can update their profile.
     * @allow (delete) User 'test_user' with ID 'test_user' can delete their profile.
     * @deny (create) User 'another_user' cannot create a profile with ID 'test_user'.
     * @deny (get) User 'another_user' cannot read the profile of user 'test_user'.
     * @deny (update) User 'another_user' cannot update the profile of user 'test_user'.
     * @deny (delete) User 'another_user' cannot delete the profile of user 'test_user'.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to game documents.
     * @path /games/{gameId}
     * @allow (get) Any user can read game data.
     * @allow (list) Any user can list game data.
     * @deny (create) No user can create game data.
     * @deny (update) No user can update game data.
     * @deny (delete) No user can delete game data.
     */
    match /games/{gameId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to team performance documents within a game.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (get) Any user can read team performance data.
     * @allow (list) Any user can list team performance data.
     * @deny (create) No user can create team performance data.
     * @deny (update) No user can update team performance data.
     * @deny (delete) No user can delete team performance data.
     */
    match /games/{gameId}/performance/{roundId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to student game state documents.
     * @path /studentGames/{userId}
     * @allow (create) User 'test_user' with ID 'test_user' can create their game state.
     * @allow (get) User 'test_user' with ID 'test_user' can read their game state.
     * @allow (update) User 'test_user' with ID 'test_user' can update their game state.
     * @allow (delete) User 'test_user' with ID 'test_user' can delete their game state.
     * @deny (create) User 'another_user' cannot create a game state with ID 'test_user'.
     * @deny (get) User 'another_user' cannot read the game state of user 'test_user'.
     * @deny (update) User 'another_user' cannot update the game state of user 'test_user'.
     * @deny (delete) User 'another_user' cannot delete the game state of user 'test_user'.
     * @principle Enforces document ownership for student game states.
     */
    match /studentGames/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}