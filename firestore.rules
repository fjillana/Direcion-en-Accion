/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a user-ownership model for user profiles and student game states,
 * and allows public read access to game data with owner-only write access.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, accessible only by the user.
 * - /games/{gameId}: Stores game data, publicly readable but writable only by the game creator (if creatorId existed).
 * - /games/{gameId}/performance/{roundId}: Stores team performance data, accessible only by the game creator (if creatorId existed) and associated game.
 * - /studentGames/{userId}: Stores the game state for each student user, accessible only by the student.
 *
 * Key Security Decisions:
 * - User profiles are private and only accessible to the owning user.
 * - Game data is publicly readable to allow for open access, but write access is restricted to the game creator (if creatorId existed).
 * - Student game states are private and only accessible to the associated user.
 * - Listing of users is disallowed.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (create) - User with ID 'user123' can create their profile if authenticated as 'user123'.
     * @allow (get, update, delete) - User with ID 'user123' can read/update/delete their profile if authenticated as 'user123'.
     * @deny (create) - User with ID 'user456' cannot create a profile with ID 'user123'.
     * @deny (get, update, delete) - User with ID 'user456' cannot read/update/delete the profile of user 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to game data.
     * @path /games/{gameId}
     * @allow (get, list) - Any user (authenticated or not) can read game data.
     * @deny (create, update, delete) -  Writes are disabled. The 'Game' entity is missing an 'ownerId' or 'authorId' field.
     * @principle Allows public read access, restricts writes to owner (missing owner field in schema).
     */
    match /games/{gameId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Controls access to team performance data for each round in a game.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (get, list) - Any user (authenticated or not) can read team performance data.
     * @deny (create, update, delete) -  Writes are disabled. The 'TeamPerformance' entity is missing an 'ownerId' or 'authorId' field.
     * @principle Allows public read access, restricts writes to owner (missing owner field in schema).
     */
    match /games/{gameId}/performance/{roundId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Controls access to student game state.
     * @path /studentGames/{userId}
     * @allow (create) - User with ID 'user123' can create their game state if authenticated as 'user123'.
     * @allow (get, update, delete) - User with ID 'user123' can read/update/delete their game state if authenticated as 'user123'.
     * @deny (create) - User with ID 'user456' cannot create a game state with ID 'user123'.
     * @deny (get, update, delete) - User with ID 'user456' cannot read/update/delete the game state of user 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /studentGames/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}