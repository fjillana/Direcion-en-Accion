/**
 * @file Firestore Security Rules
 * @description This ruleset implements a role-based access control system with a special focus on teacher permissions,
 *              allowing teachers universal access. It also enforces user-ownership for user profiles and student game states.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information. Access is restricted to the owning user and teachers.
 * - /games/{gameId}: Stores game data. Teachers have full access; students do not have direct access.
 * - /games/{gameId}/performance/{roundId}: Stores game performance data. Only teachers have access.
 * - /studentGames/{userId}: Stores the game state for each student. Teachers have full access; students can only access their own.
 *
 * Key Security Decisions:
 * - Teachers have full CRUD access to all data.
 * - Students can only read/write their own user profile and student game state.
 * - Games and performance data are only accessible to teachers.
 * - List operations are generally restricted to prevent unauthorized data discovery, except where explicitly allowed for teachers.
 *
 * Denormalization for Authorization:
 *   The teacher role is checked using the `isTeacher()` function, which reads the user's role from their profile.
 *   This avoids needing to store roles directly on game or performance documents.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user ID matches the requested ID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the requesting user has the 'teacher' role.
     */
    function isTeacher() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    /**
     * @description Checks if the user is the owner and if the resource exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for user profiles.
     * @path /users/{userId}
     * @allow (get) User A can read User A's profile.
     * @allow (create) User A can create User A's profile.
     * @allow (update) User A can update User A's profile.
     * @deny (get) User A cannot read User B's profile.
     * @deny (create) User A cannot create User B's profile.
     * @deny (update) User A cannot update User B's profile.
     * @principle Enforces document ownership for writes and read access to the owner or teacher.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isTeacher();
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id || isTeacher();
      allow delete: if isTeacher();
    }

    /**
     * @description Rules for games.
     * @path /games/{gameId}
     * @allow (get) Teachers can read any game.
     * @allow (create) Teachers can create games.
     * @allow (update) Teachers can update any game.
     * @allow (delete) Teachers can delete any game.
     * @deny (get) Students cannot read games.
     * @deny (create) Students cannot create games.
     * @deny (update) Students cannot update games.
     * @deny (delete) Students cannot delete games.
     * @principle Restricts game access to teachers only.
     */
    match /games/{gameId} {
      allow get: if isTeacher();
      allow list: if isTeacher();
      allow create: if isTeacher();
      allow update: if isTeacher() && resource != null;
      allow delete: if isTeacher() && resource != null;
    }

    /**
     * @description Rules for team performance data within a game.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (get) Teachers can read team performance data.
     * @allow (create) Teachers can create team performance data.
     * @allow (update) Teachers can update team performance data.
     * @allow (delete) Teachers can delete team performance data.
     * @deny (get) Students cannot read team performance data.
     * @deny (create) Students cannot create team performance data.
     * @deny (update) Students cannot update team performance data.
     * @deny (delete) Students cannot delete team performance data.
     * @principle Restricts team performance access to teachers only.
     */
    match /games/{gameId}/performance/{roundId} {
      allow get: if isTeacher();
      allow list: if isTeacher();
      allow create: if isTeacher();
      allow update: if isTeacher() && resource != null;
      allow delete: if isTeacher() && resource != null;
    }

    /**
     * @description Rules for student game state.
     * @path /studentGames/{userId}
     * @allow (get) User A can read User A's game state. Teachers can read any student's game state.
     * @allow (create) User A can create User A's game state.
     * @allow (update) User A can update User A's game state.
     * @deny (get) User A cannot read User B's game state.
     * @deny (create) User A cannot create User B's game state.
     * @deny (update) User A cannot update User B's game state.
     * @principle Enforces document ownership for students and allows teacher access.
     */
    match /studentGames/{userId} {
      allow get: if isOwner(userId) || isTeacher();
      allow list: if isTeacher();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId || isTeacher();
      allow delete: if isTeacher() && resource != null;
    }
  }
}