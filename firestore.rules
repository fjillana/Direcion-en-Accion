rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their own profile.
     * @allow (get) User with ID 'user123' can read their own profile.
     * @allow (update) User with ID 'user123' can update their own profile.
     * @allow (delete) User with ID 'user123' can delete their own profile.
     * @deny (get) User with ID 'user456' cannot read user 'user123' profile.
     * @deny (create) User with ID 'user456' cannot create a profile for user 'user123'.
     * @deny (update) User with ID 'user456' cannot update user 'user123' profile.
     * @deny (delete) User with ID 'user456' cannot delete user 'user123' profile.
     * @principle Enforces document ownership for all operations on user profiles.
     */
    match /users/{userId} {
      // Verify identity
      function isSignedIn() {
        return request.auth != null;
      }

      // Define owner
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      // Define isExistingOwner
      function isExistingOwner(userId) {
        return isOwner(userId);
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to game documents. Public read, owner-only write (requires 'ownerId' field).
     * @path /games/{gameId}
     * @allow (get) Any user can read a game document.
     * @allow (list) Any user can list game documents.
     * @deny (create) No one can create a game (missing owner rules).
     * @deny (update) No one can update a game (missing owner rules).
     * @deny (delete) No one can delete a game (missing owner rules).
     * @principle Allows public read access while restricting writes to the owner.
     */
    match /games/{gameId} {
      allow get, list: if true;
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow update: if request.auth.uid == resource.data.ownerId;
      allow delete: if request.auth.uid == resource.data.ownerId;
    }

    /**
     * @description Controls access to team performance documents within a game. Public read, owner-only write (requires 'ownerId' field).
     * @path /games/{gameId}/performance/{roundId}
     * @allow (get) Any user can read a team performance document.
     * @allow (list) Any user can list team performance documents.
     * @deny (create) No one can create a team performance (missing owner rules).
     * @deny (update) No one can update a team performance (missing owner rules).
     * @deny (delete) No one can delete a team performance (missing owner rules).
     * @principle Allows public read access while restricting writes to the owner.
     */
    match /games/{gameId}/performance/{roundId} {
      allow get, list: if true;
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow update: if request.auth.uid == resource.data.ownerId;
      allow delete: if request.auth.uid == resource.data.ownerId;
    }

    /**
     * @description Controls access to student game state documents.
     * @path /studentGames/{userId}
     * @allow (create) User with ID 'user123' can create their own game state.
     * @allow (get) User with ID 'user123' can read their own game state.
     * @allow (update) User with ID 'user123' can update their own game state.
     * @allow (delete) User with ID 'user123' can delete their own game state.
     * @deny (get) User with ID 'user456' cannot read user 'user123' game state.
     * @deny (create) User with ID 'user456' cannot create a game state for user 'user123'.
     * @deny (update) User with ID 'user456' cannot update user 'user123' game state.
     * @deny (delete) User with ID 'user456' cannot delete user 'user123' game state.
     * @principle Enforces document ownership for all operations on student game states.
     */
    match /studentGames/{userId} {
      // Verify identity
      function isSignedIn() {
        return request.auth != null;
      }

      // Define owner
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      // Define isExistingOwner
      function isExistingOwner(userId) {
        return isOwner(userId);
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}