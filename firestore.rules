/**
 * @file Firebase Security Rules
 * @core_philosophy This ruleset enforces a user-ownership model for user profiles and student game states. Games are publicly readable, but only authorized users can create, update, or delete them. Team performance data is tightly coupled to specific games and is only writable by authorized game controllers (not implemented).
 * @data_structure
 *   - /users/{userId}: Stores user profile data, accessible only to the owning user.
 *   - /games/{gameId}: Stores game data, publicly readable but writable only by authorized game controllers.
 *   - /games/{gameId}/performance/{roundId}: Stores team performance data, writable only by authorized game controllers.
 *   - /studentGames/{userId}: Stores student game state, accessible only to the owning user.
 * @key_security_decisions
 *   - User listing is disallowed for privacy.
 *   - Game data is publicly readable to facilitate discovery and participation.
 *   - Strict owner-only access is enforced for user profiles and student game states.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages user profile data, ensuring only the owning user can read or write their own profile.
     * @path /users/{userId}
     * @allow (create) - Authenticated user 'user_abc' can create their own profile at /users/user_abc.
     * @allow (get, update, delete) - Authenticated user 'user_abc' can read, update, or delete their profile at /users/user_abc.
     * @deny (create, get, update, delete) - Authenticated user 'user_xyz' cannot access /users/user_abc.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages game data, allowing public reads but restricting writes to authorized users.
     * @path /games/{gameId}
     * @allow (get, list) - Any user, authenticated or not, can read game data.
     * @deny (create, update, delete) - Anonymous users cannot create, update, or delete game data.
     * @principle Public read access with owner-only (or role-based) writes.
     */
    match /games/{gameId} {
      allow get, list: if true;
      allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Manages team performance data for a specific game round, restricting access to authorized game controllers.
     * @path /games/{gameId}/performance/{roundId}
     * @deny (create, get, list, update, delete) - All operations are denied in this prototype.
     * @principle Restricts access to a specific role or service account (not yet implemented).
     */
    match /games/{gameId}/performance/{roundId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Manages student game state, ensuring only the owning user can access their own game state.
     * @path /studentGames/{userId}
     * @allow (create) - Authenticated user 'user_abc' can create their own game state at /studentGames/user_abc.
     * @allow (get, update, delete) - Authenticated user 'user_abc' can read, update, or delete their game state at /studentGames/user_abc.
     * @deny (create, get, update, delete) - Authenticated user 'user_xyz' cannot access /studentGames/user_abc.
     * @principle Enforces document ownership for all operations.
     */
    match /studentGames/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }

  // --- Helper Functions ---

  /**
   * @description Checks if the request is authenticated.
   * @return {bool} True if the request is authenticated, false otherwise.
   */
  function isSignedIn() {
    return request.auth != null;
  }

  /**
   * @description Checks if the request is made by the owner of the resource.
   * @param {string} userId The user ID to compare against the request's authentication UID.
   * @return {bool} True if the request is made by the owner, false otherwise.
   */
  function isOwner(userId) {
    return isSignedIn() && request.auth.uid == userId;
  }

  /**
   * @description Checks if the request is made by the owner of an existing resource.
   * @param {string} userId The user ID to compare against the request's authentication UID.
   * @return {bool} True if the request is made by the owner and the resource exists, false otherwise.
   */
  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}