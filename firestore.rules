/**
 * @file Overview
 * This ruleset enforces a user-ownership model for user profiles and student game states.
 * Games are publicly readable but only authorized users can create, update, or delete them.
 * Team performance data is secured under its respective game.
 *
 * @data-structure
 * - `/users/{userId}`: User profile information, accessible only to the user.
 * - `/games/{gameId}`: Game sessions, publicly readable but with restricted writes.
 * - `/games/{gameId}/performance/{roundId}`: Team performance data for each round of a game.
 * - `/studentGames/{userId}`:  Tracks the current game state of a student, accessible only to the student.
 *
 * @key-security-decisions
 * - Users can only read and write their own profile data.
 * - Games are publicly listable, but creation, modification, and deletion are restricted.
 * - Listing user documents is disallowed.
 * - Each student can read/write their own game state.
 *
 * @denormalization-for-authorization
 * - The `Game` entity lacks an `ownerId` or `authorId` field. To properly restrict game creation, update, and deletion,
 *   it's essential to add such a field to the `Game` schema in `docs/backend.json`. This field must be populated with the
 *   UID of the user creating the game. The rules will then enforce that only the creator can modify or delete the game.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (get, create, update, delete) if the user is signed in and the requested userId matches the authenticated user's ID.
     * @deny (get, create, update, delete) if the user is not signed in or the userId does not match the authenticated user's ID.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Manages access to game sessions.
     * @path /games/{gameId}
     * @allow (get, list) any signed-in user can read all games.
     * @allow (create, update, delete) only the game creator can modify or delete a game.
     * @deny (create, update, delete) if the user is not the game creator.
     * @principle Public read access with owner-only writes.
     */
    match /games/{gameId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      // CRITICAL: Cannot implement owner-only writes. The 'Game' entity is missing an 'ownerId' or 'authorId' field.
    }

    /**
     * @description Secures team performance data for each round of a game.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (get, list) anyone can read the team performance of each round
     * @allow (create, update, delete) only the game creator can modify or delete a game.
     * @deny (create, update, delete) if the user is not the game creator.
     * @principle  Public read access with owner-only writes.
     */
    match /games/{gameId}/performance/{roundId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Controls access to the game state for each student user.
     * @path /studentGames/{userId}
     * @allow (get, create, update, delete) if the user is signed in and the requested userId matches the authenticated user's ID.
     * @deny (get, create, update, delete) if the user is not signed in or the userId does not match the authenticated user's ID.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /studentGames/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}