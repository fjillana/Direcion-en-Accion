rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages user profile data. Teachers can create profiles (likely during onboarding),
     *              and users can update their own profiles. Listing all users is disallowed.
     * @path /users/{userId}
     * @allow (create) - A teacher creates a new user profile. (auth.uid = teacher_uid, request.resource.data.role = 'student')
     * @allow (update) - A user updates their own profile. (auth.uid = user_id)
     * @deny (create) - A student attempts to create a profile for another user. (auth.uid = student_uid, request.resource.data.id != student_uid)
     * @deny (delete) - Any user attempts to delete a profile.
     * @principle Enforces document ownership for updates and restricts user listing.
     */
    match /users/{userId} {
      function isTeacher() {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return userDoc.data.role == 'teacher';
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && isTeacher();
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if false;
    }

    /**
     * @description Manages game session data. Teachers can create, update, and delete games.
     *              All users can read game data.
     * @path /games/{gameId}
     * @allow (create) - A teacher creates a new game. (auth.uid = teacher_uid)
     * @allow (update) - A teacher updates an existing game. (auth.uid = teacher_uid)
     * @allow (get) - Any user retrieves game data.
     * @deny (create) - A student attempts to create a game. (auth.uid = student_uid)
     * @deny (delete) - A student attempts to delete a game.
     * @principle Enforces teacher-only access for write operations, allows public reads.
     */
    match /games/{gameId} {
      function isTeacher() {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return userDoc.data.role == 'teacher';
      }
      function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isTeacher();
      allow update: if isSignedIn() && isTeacher();
      allow delete: if isSignedIn() && isTeacher();
    }

    /**
     * @description Manages team performance data within a game session. Only teachers can create, update, or delete performance data.
     *              All users can read performance data.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (create) - A teacher creates team performance data for a round. (auth.uid = teacher_uid)
     * @allow (update) - A teacher updates team performance data for a round. (auth.uid = teacher_uid)
     * @allow (get) - Any user retrieves team performance data.
     * @deny (create) - A student attempts to create performance data. (auth.uid = student_uid)
     * @deny (delete) - A student attempts to delete performance data.
     * @principle Enforces teacher-only access for write operations, allows public reads.
     */
    match /games/{gameId}/performance/{roundId} {
      function isTeacher() {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return userDoc.data.role == 'teacher';
      }
      function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isTeacher();
      allow update: if isSignedIn() && isTeacher();
      allow delete: if isSignedIn() && isTeacher();
    }

    /**
     * @description Manages the game state for individual students. Students can only modify their own game state.
     * @path /studentGames/{userId}
     * @allow (create) - A student creates their own game state. (auth.uid = user_id)
     * @allow (update) - A student updates their own game state. (auth.uid = user_id)
     * @allow (get) - Any user retrieves a student's game state.
     * @deny (create) - A student attempts to create a game state for another user. (auth.uid = student_uid, request.resource.data.userId != student_uid)
     * @deny (delete) - Any user attempts to delete a student's game state.
     * @principle Enforces document ownership for updates and restricts user listing.
     */
    match /studentGames/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if false;
    }
  }
}