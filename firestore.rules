/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset prioritizes rapid development by granting authenticated users broad access.
 * This enables quick iteration on the application's features without being blocked by overly restrictive permissions.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, accessible only by the user.
 * - /games/{gameId}: Stores general game information, accessible to all authenticated users.
 * - /games/{gameId}/performance/{roundId}: Stores performance data for each game round, accessible to all authenticated users.
 * - /studentGames/{userId}: Stores the game state for each student, accessible only by that student.
 *
 * Key Security Decisions:
 * - Authenticated User Requirement: All read and write operations require authentication, preventing anonymous access.
 * - No Data Validation: These rules do not enforce data validation, allowing for flexible schema changes during prototyping.
 * - Ownership Enforcement: User profiles and student game states are secured using strict ownership checks, ensuring users can only access their own data.
 * - Broad Game Access: All games and their associated performance data are accessible to any authenticated user.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows authenticated users to manage their own user profile.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' creates their own profile.
     * @deny (create) User with ID 'user123' attempts to create a profile for 'user456'.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Allows any authenticated user to read and write game data.
     * @path /games/{gameId}
     * @allow (create) Authenticated user creates a new game.
     * @deny (create) Unauthenticated user attempts to create a game.
     * @principle Grants broad access to game data for authenticated users.
     */
    match /games/{gameId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read and write team performance data for each round of the game.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (create) Authenticated user creates a new round of performance data.
     * @deny (create) Unauthenticated user attempts to create round performance data.
     * @principle Grants broad access to game data for authenticated users.
     */
    match /games/{gameId}/performance/{roundId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows authenticated users to manage their own student game state.
     * @path /studentGames/{userId}
     * @allow (create) Student with ID 'student123' creates their own game state.
     * @deny (create) Student with ID 'student123' attempts to create a game state for 'student456'.
     * @principle Enforces document ownership for student game states.
     */
    match /studentGames/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}