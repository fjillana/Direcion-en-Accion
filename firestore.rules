/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset prioritizes developer velocity by granting all authenticated users full access to the database.
 * The application is responsible for handling authorization based on user roles and UI restrictions.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, with document ID matching the user's UID.
 * - /games/{gameId}: Stores game data.
 * - /games/{gameId}/performance/{roundId}: Stores team performance data for each round of a game.
 * - /studentGames/{userId}: Stores the game state for each student, with document ID matching the user's UID.
 *
 * Key Security Decisions:
 * - All authenticated users can read and write all data.
 * - Access control is handled within the application logic.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows any authenticated user to read or write user profile data.
     * @path /users/{userId}
     * @allow (read, write) - Any authenticated user can access any user profile.
     * @deny (none) - No restrictions on access.
     * @principle Grants full access to any authenticated user
     */
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read or write game data.
     * @path /games/{gameId}
     * @allow (read, write) - Any authenticated user can access any game.
     * @deny (none) - No restrictions on access.
     * @principle Grants full access to any authenticated user
     */
    match /games/{gameId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();

      /**
       * @description Allows any authenticated user to read or write team performance data.
       * @path /games/{gameId}/performance/{roundId}
       * @allow (read, write) - Any authenticated user can access any team performance data.
       * @deny (none) - No restrictions on access.
       * @principle Grants full access to any authenticated user
       */
      match /performance/{roundId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }
    }

    /**
     * @description Allows any authenticated user to read or write student game state data.
     * @path /studentGames/{userId}
     * @allow (read, write) - Any authenticated user can access any student game state.
     * @deny (none) - No restrictions on access.
     * @principle Grants full access to any authenticated user
     */
    match /studentGames/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }

  function isSignedIn() {
    return request.auth != null;
  }
}