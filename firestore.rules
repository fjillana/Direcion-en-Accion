/**
 * @description This ruleset enforces a role-based access control system where teachers can create, update, and delete games,
 *              and users (both teachers and students) can only manage their own profile and game state information.
 * @dataStructure
 *  - /users/{userId}: Stores user profiles. Accessible only by the user themselves.
 *  - /games/{gameId}: Stores game information. Teachers can create, update, and delete games. All authenticated users can read games.
 *  - /games/{gameId}/performance/{roundId}: Stores team performance data for each round of a game. Accessible only to teachers.
 *  - /studentGames/{userId}: Stores the game state for each student user. Accessible only by the user themselves.
 * @keySecurityDecisions
 *  - User listing is explicitly denied.
 *  - Teachers are authorized to manage games, leveraging the 'teacher' role stored in the user's profile.
 *  - Data is denormalized so game documents have `createdBy` field equal to the teacher's `uid`.
 * @denormalizationForAuthorization
 *  - Games should store the UID of the creating teacher in a `createdBy` field to enable ownership checks.
 * @structuralSegregation
 *  - No structural segregation implemented.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isTeacher() {
      return isSignedIn() && getUserRole() == 'teacher';
    }

    function isGameOwner(gameId) {
      return isTeacher() && 
             get(/databases/$(database)/documents/games/$(gameId)).data.createdBy == request.auth.uid;
    }

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (read, write) Authenticated user can only access their own profile.
     * @deny (read, write) Authenticated user tries to access another user's profile.
     * @principle Enforces user-ownership for profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // User listing is not allowed
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Controls access to game information.
     * @path /games/{gameId}
     * @allow (read) Any authenticated user can read game information.
     * @allow (create) Teachers can create new games. The 'createdBy' field must match the teacher's UID.
     * @allow (update, delete) Only the teacher who created the game can update or delete it.
     * @deny (create) Non-teachers cannot create games.
     * @deny (update, delete) Non-owners cannot update or delete games.
     * @principle Enforces teacher-ownership for game data.
     */
    match /games/{gameId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isTeacher();
      allow update, delete: if isGameOwner(gameId);
    }

    /**
     * @description Controls access to team performance data for each round of a game.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (read, write) Only teachers can access team performance data.
     * @deny (read, write) Students cannot access team performance data.
     * @principle Restricts access to performance data to teachers only.
     */
    match /games/{gameId}/performance/{roundId} {
      allow get: if isTeacher();
      allow list: if isTeacher();
      allow create: if isTeacher();
      allow update: if isTeacher();
      allow delete: if isTeacher();
    }

    /**
     * @description Controls access to the game state for each student user.
     * @path /studentGames/{userId}
     * @allow (read, write) Authenticated user can only access their own game state.
     * @deny (read, write) Authenticated user tries to access another user's game state.
     * @principle Enforces user-ownership for student game state data.
     */
    match /studentGames/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // User listing is not allowed
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
  }
}