rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (get, update, delete) Authenticated user can access their own profile.
     * @allow (create) Authenticated user can create their own profile, matching their UID.
     * @deny (get, update, delete) User attempts to access another user's profile.
     * @deny (list) Listing users is not allowed.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && exists(resource);
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to game information.
     * @path /games/{gameId}
     * @allow (get, list) Any user can read game information.
     * @allow (create) Authenticated user can create a game, with `createdBy` field set to their UID.
     * @allow (update, delete) Only the user who created the game can update or delete it.
     * @deny (update, delete) User attempts to modify a game they did not create.
     * @principle Allows public read access with owner-only writes.
     */
    match /games/{gameId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(gameId, userId) {
        return get(/databases/$(database)/documents/games/$(gameId)).data.createdBy == userId;
      }

      function isCreatingOwner() {
        return request.resource.data.createdBy == request.auth.uid;
      }

      function isExistingOwner(gameId, userId) {
        return isOwner(gameId, userId) && exists(resource);
      }

      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isCreatingOwner();
      allow update: if isSignedIn() && isExistingOwner(gameId, request.auth.uid);
      allow delete: if isSignedIn() && isExistingOwner(gameId, request.auth.uid);
    }

    /**
     * @description Controls access to team performance data for each round of a game.
     * @path /games/{gameId}/performance/{roundId}
     * @allow (create, update, delete) Only the user who created the game can write performance data.
     * @deny (get, list) Prevents listing or reading individual round performance documents directly.
     * @principle Restricts writes to the game creator.
     */
    match /games/{gameId}/performance/{roundId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function getGameCreator(gameId) {
        return get(/databases/$(database)/documents/games/$(gameId)).data.createdBy;
      }

      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn() && getGameCreator(gameId) == request.auth.uid;
      allow update: if isSignedIn() && getGameCreator(gameId) == request.auth.uid;
      allow delete: if isSignedIn() && getGameCreator(gameId) == request.auth.uid;
    }

    /**
     * @description Controls access to student game state.
     * @path /studentGames/{userId}
     * @allow (get, update, delete) Authenticated user can access their own game state.
     * @allow (create) Authenticated user can create their own game state, matching their UID.
     * @deny (get, update, delete) User attempts to access another user's game state.
     * @deny (list) Listing student game states is not allowed.
     * @principle Enforces document ownership for writes.
     */
    match /studentGames/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && exists(resource);
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }
  }
}