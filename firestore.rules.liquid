
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    {%- for path, path_config in firestore %}
    match {{ path }} {
      allow read: if true; // Default open rule, adjust as needed
      allow write: if request.auth != null; // Default rule: only authenticated users can write
    }
    {%- endfor %}
  }
}
