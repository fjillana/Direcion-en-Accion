/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control model. Users have roles (teacher, student). Teachers can create and manage games.
 * Users can only access their own user profiles and student game states.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, including role.
 * - /games/{gameId}: Stores game information. Games have a creator (teacher).
 * - /studentGames/{userId}: Stores the game state for each student.
 *
 * Key Security Decisions:
 * - Only authenticated users can read games.
 * - Only the teacher who created a game can modify it.
 * - Users can only read and write their own user profiles and student game states.
 * - Listing of users and studentGames is disallowed for non-owners.
 *
 * Denormalization for Authorization:
 * The `createdBy` field is expected on the `Game` entity to store the teacher who created the game.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    
    // Regla para acceder al rol del usuario desde /users/{userId}
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Regla para verificar si el usuario es profesor
    function isTeacher() {
      return request.auth != null && getUserRole() == 'teacher';
    }

    // Regla para verificar si el usuario es el creador de la partida
    function isGameOwner(gameId) {
      return isTeacher() && 
             get(/databases/$(database)/documents/games/$(gameId)).data.createdBy == request.auth.uid;
    }

    /**
     * @description Allows users to read and write their own user profile.
     * @path /users/{userId}
     * @allow (read, write) if the user is signed in and the requested userId matches their auth UID.
     * @deny (read, write) if the user is not signed in, or the userId does not match their auth UID.
     * @principle Enforces user-ownership; only the authenticated user can access their own profile.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows authenticated users to read games. Only the teacher who created the game can create, update or delete it.
     * @path /games/{gameId}
     * @allow (read) if the user is signed in.
     * @allow (create, update, delete) if the user is a teacher and created the game.
     * @deny (create, update, delete) if the user is not a teacher or did not create the game.
     * @principle Enforces role-based access control; only teachers can manage games they created.
     */
    match /games/{gameId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isTeacher() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isGameOwner(gameId) && resource != null;
      allow delete: if isGameOwner(gameId) && resource != null;
    }

     /**
      * @description Allows a teacher to read/write TeamPerformance documents for a given game and round.
      * @path /games/{gameId}/performance/{roundId}
      * @allow (get, list) if the user is signed in and is the game owner.
      * @allow (create, update, delete) if the user is signed in and is the game owner.
      * @deny (get, list, create, update, delete) if the user is not the game owner.
      * @principle Enforces that only the owner of a game can modify or delete team performance data.
      */
    match /games/{gameId}/performance/{roundId} {
        allow get: if isGameOwner(gameId);
        allow list: if isGameOwner(gameId);
        allow create: if isGameOwner(gameId);
        allow update: if isGameOwner(gameId) && resource != null;
        allow delete: if isGameOwner(gameId) && resource != null;
    }

    /**
     * @description Allows users to read and write their own student game state.
     * @path /studentGames/{userId}
     * @allow (read, write) if the user is signed in and the requested userId matches their auth UID.
     * @deny (read, write) if the user is not signed in, or the userId does not match their auth UID.
     * @principle Enforces user-ownership; only the authenticated user can access their own student game state.
     */
    match /studentGames/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}